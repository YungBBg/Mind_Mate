{
  "expo": {
    "name": "Mind Mate",
    "slug": "mind-mate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindmate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.mindmate.app"
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "mindmate"
  }
}
